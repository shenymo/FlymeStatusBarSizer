<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application
        android:allowBackup="false"
        android:description="@string/module_description"
        android:directBootAware="true"
        android:extractNativeLibs="false"
        android:hasCode="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".AdvancedSettingsActivity"
            android:exported="false"
            android:label="@string/advanced_settings_title" />

        <activity
            android:name=".BatterySettingsActivity"
            android:exported="false"
            android:label="iOS 风格电池" />

        <provider
            android:name=".SettingsProvider"
            android:authorities="com.example.flymestatusbarsizer.settings"
            android:directBootAware="true"
            android:exported="true" />
    </application>
</manifest>
